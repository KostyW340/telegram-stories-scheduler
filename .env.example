# Telegram bot used as the operator control panel.
BOT_TOKEN=
BOT_ALLOWED_USER_IDS=
# Optional: only set this when using a custom or local Bot API server.
BOT_API_BASE_URL=
# Optional: proxy for Telegram Bot API traffic.
# Example: http://127.0.0.1:8080 or socks5://127.0.0.1:1080
BOT_PROXY_URL=

# Telegram user account that will publish the stories.
API_ID=
API_HASH=
PHONE_NUMBER=
SESSION_NAME=account
CLIENT_DEVICE_MODEL=Desktop
CLIENT_SYSTEM_VERSION=Windows 10 x64
CLIENT_APP_VERSION=6.5.1 x64
CLIENT_LANG_CODE=ru
CLIENT_SYSTEM_LANG_CODE=ru
# Optional: MTProto proxy routing. Set host and port together; secret is optional.
TELEGRAM_MTPROXY_HOST=
TELEGRAM_MTPROXY_PORT=
TELEGRAM_MTPROXY_SECRET=

# Runtime behavior.
APP_TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO
SCHEDULER_POLL_INTERVAL_SECONDS=15
WORKER_BATCH_SIZE=10
JOB_LOCK_TTL_SECONDS=900
PUBLISH_RETRY_MAX_ATTEMPTS=5
PUBLISH_RETRY_BASE_DELAY_SECONDS=15
PUBLISH_RETRY_MAX_DELAY_SECONDS=180
PUBLISH_RETRY_WINDOW_SECONDS=900
PUBLISH_RETRY_MAX_FLOOD_WAIT_SECONDS=300
ONE_TIME_MIN_LEAD_SECONDS=120
CONNECTIVITY_SUMMARY_INTERVAL_SECONDS=60
MTPROTO_PROBE_INTERVAL_SECONDS=60
MTPROTO_CONNECT_TIMEOUT_SECONDS=45
MTPROTO_PROBE_TIMEOUT_SECONDS=10
MTPROTO_PUBLISH_TIMEOUT_SECONDS=3600
WORKER_CYCLE_TIMEOUT_SECONDS=7200
BOT_POLLING_BACKOFF_MIN_DELAY_SECONDS=1
BOT_POLLING_BACKOFF_MAX_DELAY_SECONDS=60
BOT_POLLING_BACKOFF_FACTOR=1.8
BOT_POLLING_BACKOFF_JITTER=0.2
BOT_POLLING_BACKOFF_RESET_AFTER_SECONDS=300

# Local runtime paths. Keep real data out of git.
DATA_DIR=data
DB_PATH=tasks.db
PHOTOS_DIR=photos
VIDEOS_DIR=videos
PREPARED_PHOTOS_DIR=prepared/photos
PREPARED_VIDEOS_DIR=prepared/videos
TEMP_DIR=data/tmp
LOGS_DIR=data/logs
SESSIONS_DIR=.

# Media tooling.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
MAX_VIDEO_DURATION_SECONDS=60
MAX_VIDEO_SIZE_BYTES=524288000
